# Production environment for Vercel
# API calls use /api (relative) which is proxied via vercel.json rewrites
# Do NOT set NEXT_PUBLIC_API_URL to an absolute URL - it bypasses the proxy
NEXT_PUBLIC_SOCKET_URL=https://security-api-new.vercel.app
NEXT_PUBLIC_APP_NAME=ProctoredExam
NEXT_PUBLIC_APP_URL=https://proctorexam.vercel.app
